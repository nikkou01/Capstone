MONGO_URL=mongodb://localhost:27017
DB_NAME=safecctv
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SMS API integration (optional)
SMS_API_URL=https://unismsapi.com/api/sms
SMS_API_KEY=sk_e3db877f-727f-464d-bdb3-f5d6a6f01214
SMS_API_KEY_NAME=accident_detection
SMS_API_AUTH_HEADER=Authorization
SMS_API_AUTH_SCHEME=Basic
SMS_API_FROM=
SMS_API_TO_FIELD=recipient
SMS_API_MESSAGE_FIELD=content
SMS_API_FROM_FIELD=sender_id
SMS_API_EXTRA_JSON={"metadata":{"source":"accident_detection"}}
SMS_API_TIMEOUT_SECONDS=15
PUBLIC_BASE_URL=http://127.0.0.1:8001

# Collision clip recording
COLLISION_CLIP_SECONDS=15
COLLISION_PRE_EVENT_SECONDS=10
COLLISION_CLIP_FPS=10

# Simulation upload tuning
SIMULATION_ANALYSIS_FPS=6
SIMULATION_MAX_ANALYZED_FRAMES=900

# Live dashboard stream tuning
LIVE_STREAM_FPS=30
LIVE_STREAM_DRAIN_GRABS=0
LIVE_STREAM_MAX_CATCHUP_GRABS=3
LIVE_STREAM_JPEG_QUALITY=55
LIVE_STREAM_MAX_WIDTH=960
LIVE_STREAM_MAX_HEIGHT=0
LIVE_STREAM_MAX_READ_FAILURES=20
RTSP_VALIDATION_TIMEOUT_SECONDS=5
RTSP_VALIDATION_RETRY_INTERVAL_SECONDS=0.05
CAMERA_RECONNECT_FAIL_AFTER_SECONDS=30
LIVE_RTSP_TRANSPORT=udp
LIVE_FORCE_SUBTYPE0=1
PREBUFFER_ACTIVE_CAMERAS_ON_STARTUP=0

# Live AI collision detection (YOLO)
DETECTION_ENABLED=1
DETECTION_MODEL_PATH=backend/models/best.pt
DETECTION_CONFIDENCE_THRESHOLD=0.01
DETECTION_COOLDOWN_SECONDS=12
DETECTION_POLL_INTERVAL_SECONDS=0.10
# Optional filters (comma-separated). Leave blank to accept any detected class.
DETECTION_ALLOWED_CLASS_IDS=
DETECTION_ALLOWED_CLASS_NAMES=
DETECTION_DESCRIPTION_PREFIX=Auto-detected collision
